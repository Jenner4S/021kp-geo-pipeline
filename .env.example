# 021kp GEO Pipeline - 环境变量配置模板
# 复制为 .env 并填入真实值: cp .env.example .env

# ==================== MySQL 数据库 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=021kp_db
DB_SSL=false
# DB_CA=/path/to/ca.pem  # SSL证书路径(生产环境必填)

# ==================== 微信公众号 API (Phase 4) ====================
WECHAT_APPID=wx_your_appid_here
WECHAT_SECRET=your_wechat_secret_here
WECHAT_TEMPLATE_ID=your_template_id_here
# WECHAT_TOKEN=  # 消息验证token(如需回调)

# ==================== 抖音/豆包 API ====================
DOUYIN_APP_ID=your_douyin_app_id
DOUYIN_TOKEN=your_douyin_access_token
DOUYIN_API_URL=https://open.douyin.com

# ==================== 百度文心一言 API ====================
BAIDU_API_KEY=your_baidu_api_key
BAIDU_SECRET_KEY=your_baidu_secret_key
BAIDU_WENXIN_URL=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop/chat/completions_pro

# ==================== 企业微信告警(可选) ====================
WEBCOM_HOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your_key_here

# ==================== 运行时配置 ====================
GEO_MODE=pipeline          # pipeline / db / server / import
LOG_LEVEL=INFO             # DEBUG / INFO / WARNING / ERROR
LOG_DIR=./audit_logs       # 审计日志目录
OUTPUT_DIR=./dist          # GEO输出文件目录

# 监控配置(Dist Monitor)
MONITOR_ENABLED=true
CITATION_THRESHOLD=0.5     # 引用率阈值(<此值触发告警)
ALERT_WEBHOOK=${WEBCOM_HOOK_URL}

# ==================== Docker Compose 特有 ====================
MYSQL_ROOT_PASSWORD=changeme_in_production
